pipeline {

    agent any

    stages {

        stage('Clone Repository') {
            steps {
                git 'https://github.com/firdosneha/devops-prt.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t prt-image .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 8081:80 prt-image'
            }
        }

    }
}
